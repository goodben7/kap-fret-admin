# ─── Développement local ───────────────────────────────────────────────────────
# Laisser VITE_API_BASE_URL vide : les requêtes passent par le proxy Vite (/api → backend).
VITE_API_BASE_URL=

# Cible du proxy Vite (dev uniquement, ignoré en production)
VITE_PROXY_TARGET=https://localhost:8000

# ─── Production (Netlify) ──────────────────────────────────────────────────────
# URL de base du backend SANS le suffixe /api (les services appellent déjà /api/...).
# À configurer dans Netlify : Site settings → Environment variables
#
# VITE_API_BASE_URL=https://api.kap-fret.ereborhub.cloud

# ─── Auth (référence) ─────────────────────────────────────────────────────────
# POST /api/authentication_token  { "username": "...", "password": "..." }
# GET  /api/users/about           (utilisateur connecté, Bearer token)
